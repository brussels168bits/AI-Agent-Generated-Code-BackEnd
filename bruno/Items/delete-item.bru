meta {
  name: delete item (soft)
  type: http
  seq: 7
}

delete {
  url: {{baseUrl}}/api/v1/items/{{itemId}}
  body: json
  auth: none
}

headers {
  content-type: application/json
  x-gateway-token: {{gatewayToken}}
  x-ou-id: {{ouId}}
  x-branch-id: {{branchId}}
  x-user-id: {{userId}}
}

body:json {
  {
    "upd_date": "{{updDate}}"
  }
}
