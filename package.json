{
  "name": "ai-agent-generated-code-from-requirements",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.11.0"
  },
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "lint": "eslint src scripts",
    "format": "prettier --write \"src/**/*.js\" \"scripts/**/*.js\"",
    "test": "node --test",
    "test:unit": "node --test src/**/tests/unit-test/*.js",
    "test:integration": "node --test src/**/tests/integration-test/*.js",
    "audit:check": "npm audit --audit-level=moderate",
    "db:items-indexes": "node scripts/create-items-indexes.js"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "joi": "^17.13.0",
    "mongodb": "^6.6.0",
    "pino": "^9.2.0",
    "pino-pretty": "^11.0.0"
  },
  "devDependencies": {
    "eslint": "^9.12.0",
    "globals": "^15.11.0",
    "prettier": "^3.2.5"
  }
}
